# Supabase — copy from Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here  # Backend only, never client

# OSRM (swap to self-hosted URL in production)
OSRM_BASE_URL=http://router.project-osrm.org

# Hugging Face (YOLOv8n inference endpoint)
HF_INFERENCE_URL=https://your-space.hf.space/predict

# Open-Meteo (no key needed — free, no auth)
WEATHER_API_BASE=https://api.open-meteo.com/v1/forecast

# Expo Push Notifications
EXPO_ACCESS_TOKEN=your-expo-token

# Next.js ISR revalidation (generate with: openssl rand -hex 32)
REVALIDATION_SECRET=your-random-secret-here
